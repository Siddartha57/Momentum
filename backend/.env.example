# === App Config ===
APP_NAME=Momentum
ENVIRONMENT=development
# Change to 'production' when deploying

# === Security ===
SECRET_KEY=change-this-secret
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Database ===
# SQLite for development:
DATABASE_URL=sqlite:///./momentum.db
# PostgreSQL for production (Railway provides this):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Frontend URL ===
FRONTEND_URL=http://localhost:5173
# Change to your Vercel URL in production:
# FRONTEND_URL=https://your-app.vercel.app

